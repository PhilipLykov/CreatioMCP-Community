# CreatioMCP Community Edition Configuration
# Copy this file to .env and fill in your values

# ─── Default Creatio Environment (optional, can configure via tools) ───
CREATIO_DEFAULT_URL=https://mysite.creatio.com
CREATIO_DEFAULT_AUTH_TYPE=cookie
CREATIO_DEFAULT_LOGIN=Supervisor
CREATIO_DEFAULT_PASSWORD=

# ─── Logging ───
MCP_LOG_LEVEL=info
# trace | debug | info | warn | error

# ─── Academy Knowledge Base ───
CREATIO_ACADEMY_DB_PATH=
# Path to academy.db SQLite file. Default: ./data/academy.db
# Generate by running: cd tools/academy-scraper && npx tsx scrape.ts

# ─── Security ───
CREATIO_ALLOW_SELF_SIGNED_CERTS=false
# Set to true ONLY for development environments with self-signed certificates
